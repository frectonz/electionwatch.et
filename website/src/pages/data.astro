---
import Layout from "@/layouts/Layout.astro";
import { datasets } from "@/data/datasets";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import {
  ArrowRight,
  ArrowUpRight,
  Database,
  Sparkles,
  Copy,
} from "@lucide/astro";

const SITE = "https://electionwatch.et";
const LLMS_URL = `${SITE}/llms.txt`;

// The ready-made prompt we copy / prefill. It points the model at llms.txt,
// which maps every dataset and links the raw JSON.
const AGENT_PROMPT = `Read ${LLMS_URL} — it's the entry point for electionwatch.et, an open-data project on Ethiopia's 7th General Election. It maps every dataset (candidates, polling stations, debate analyses, party positions, and ballot symbols) and links to the raw JSON, with the full file list at ${SITE}/data/manifest.json. Load it and the files it references, then help me explore and analyze the data, citing the source files you use.`;

// Only ChatGPT and Perplexity accept a prompt straight from the URL; Claude and
// Gemini don't, so for those we open a fresh chat and rely on the clipboard
// copy (the script copies the prompt on every click).
const assistants = [
  {
    name: "ChatGPT",
    href: `https://chatgpt.com/?q=${encodeURIComponent(AGENT_PROMPT)}`,
    prefill: true,
  },
  {
    name: "Claude",
    href: "https://claude.ai/new",
    prefill: false,
  },
  {
    name: "Gemini",
    href: "https://gemini.google.com/app",
    prefill: false,
  },
  {
    name: "Perplexity",
    href: `https://www.perplexity.ai/search/new?q=${encodeURIComponent(AGENT_PROMPT)}`,
    prefill: true,
  },
];
---

<Layout
  title="Data · electionwatch.et"
  description="Open datasets on Ethiopia's 7th General Election."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <Breadcrumbs items={[{ label: "Data" }]} />
    <h1 class="font-display text-4xl sm:text-5xl mb-4">Datasets</h1>
    <p class="text-ew-text-dim text-lg max-w-2xl">
      Every entry links to its source.
    </p>
  </section>

  <!-- Talk to the data in your own LLM -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
    <div
      data-llm-cta
      data-prompt={AGENT_PROMPT}
      class="bg-ew-gold-soft border border-ew-gold/20 rounded-xl p-6 sm:p-8 flex flex-col gap-4"
    >
      <div class="flex items-start gap-3">
        <div
          class="w-10 h-10 rounded-lg bg-ew-shell/10 grid place-items-center shrink-0"
        >
          <Sparkles class="w-5 h-5 text-ew-shell" />
        </div>
        <div class="min-w-0">
          <h2 class="font-display text-2xl text-ew-text leading-tight">
            Explore this with your favorite LLM
          </h2>
          <p
            class="text-ew-text-dim text-sm sm:text-base leading-relaxed mt-2 max-w-2xl"
          >
            The whole site is published as plain JSON behind a single
            <code class="text-ew-shell">llms.txt</code> entry point. Open it in your
            assistant of choice and ask your own questions, or copy the ready-made
            prompt and paste it anywhere. Each record stays linked to its source,
            so the model can cite where a number came from.
          </p>
        </div>
      </div>

      <!-- One-click launchers -->
      <div class="flex flex-wrap gap-2">
        {
          assistants.map((a) => (
            <a
              href={a.href}
              target="_blank"
              rel="noopener noreferrer"
              data-open
              data-name={a.name}
              data-prefill={String(a.prefill)}
              class="inline-flex items-center gap-2 bg-ew-card border border-ew-card-border rounded-lg px-4 py-2 text-sm font-medium text-ew-text hover:border-ew-shell/40 transition-colors"
            >
              Open in {a.name}
              <ArrowUpRight class="w-3.5 h-3.5 text-ew-text-muted" />
            </a>
          ))
        }
        <button
          type="button"
          data-copy
          class="inline-flex items-center gap-2 bg-ew-shell text-white rounded-lg px-4 py-2 text-sm font-medium hover:opacity-90 transition-opacity"
        >
          <Copy class="w-4 h-4" /> Copy prompt
        </button>
      </div>

      <p
        data-status
        role="status"
        aria-live="polite"
        class="text-xs text-ew-text-muted opacity-0 transition-opacity min-h-4"
      >
      </p>

      <p class="text-xs text-ew-text-muted leading-relaxed">
        Claude and Gemini can&rsquo;t take a prompt from a link, so we copy it
        to your clipboard on click &mdash; just paste it in. Prefer to wire it
        up yourself? Open
        <a href="/llms.txt" class="text-ew-shell hover:text-ew-gold">llms.txt</a
        >
        or the
        <a href="/data/manifest.json" class="text-ew-shell hover:text-ew-gold"
          >data manifest</a
        >.
      </p>

      <details class="text-xs text-ew-text-muted">
        <summary class="cursor-pointer hover:text-ew-shell select-none">
          Preview the prompt
        </summary>
        <p
          class="mt-2 bg-ew-card border border-ew-card-border rounded-lg p-3 text-ew-text-dim leading-relaxed font-mono"
        >
          {AGENT_PROMPT}
        </p>
      </details>
    </div>
  </section>

  <script>
    const root = document.querySelector<HTMLElement>("[data-llm-cta]");
    if (root) {
      const prompt = root.dataset.prompt ?? "";
      const status = root.querySelector<HTMLElement>("[data-status]");
      let timer = 0;
      const flash = (msg: string) => {
        if (!status) return;
        status.textContent = msg;
        status.classList.remove("opacity-0");
        clearTimeout(timer);
        timer = window.setTimeout(
          () => status.classList.add("opacity-0"),
          6000,
        );
      };
      const copyPrompt = async (): Promise<boolean> => {
        try {
          await navigator.clipboard.writeText(prompt);
          return true;
        } catch {
          return false;
        }
      };
      root.querySelectorAll<HTMLAnchorElement>("[data-open]").forEach((el) => {
        el.addEventListener("click", () => {
          const prefill = el.dataset.prefill === "true";
          const name = el.dataset.name ?? "the assistant";
          void copyPrompt().then((ok) => {
            if (prefill) {
              flash(`Opening ${name} with the prompt ready to send.`);
            } else if (ok) {
              flash(`Prompt copied — paste it into ${name} and send.`);
            } else {
              flash(`Opening ${name} — use “Copy prompt”, then paste.`);
            }
          });
        });
      });
      root
        .querySelector<HTMLButtonElement>("[data-copy]")
        ?.addEventListener("click", () => {
          void copyPrompt().then((ok) =>
            flash(
              ok
                ? "Prompt copied to your clipboard."
                : "Couldn’t access the clipboard — select the preview text and copy it.",
            ),
          );
        });
    }
  </script>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid md:grid-cols-2 gap-5">
      {
        datasets.map((d) => {
          const isLive = d.status === "live";
          const Wrapper = isLive ? "a" : "div";
          return (
            <Wrapper
              href={isLive ? d.href : undefined}
              class={`group bg-ew-card border border-ew-card-border rounded-xl p-6 flex flex-col gap-3 ${
                isLive
                  ? "hover:border-ew-shell/40 hover:shadow-md transition-all"
                  : "opacity-75"
              }`}
            >
              <Database class="w-6 h-6 text-ew-shell" />
              <h2 class="font-display text-2xl leading-tight group-hover:text-ew-shell transition-colors">
                {d.title}
                {!isLive && (
                  <span class="ml-2 text-xs uppercase tracking-wider text-ew-text-muted font-body font-normal align-middle">
                    coming soon
                  </span>
                )}
              </h2>
              <p class="text-ew-text-dim text-sm leading-relaxed flex-1">
                {d.blurb}
              </p>
              <dl class="grid grid-cols-2 gap-2 text-xs mt-1">
                <div>
                  <dt class="text-ew-text-muted uppercase tracking-wider mb-0.5">
                    Records
                  </dt>
                  <dd class="font-mono text-ew-text tabular-nums">
                    {d.records.toLocaleString("en-US")} {d.recordsLabel}
                  </dd>
                </div>
                <div>
                  <dt class="text-ew-text-muted uppercase tracking-wider mb-0.5">
                    Sources
                  </dt>
                  <dd class="text-ew-text-dim">{d.sources.join(", ")}</dd>
                </div>
              </dl>
              {isLive && (
                <div class="text-sm text-ew-shell inline-flex items-center gap-1 mt-2 opacity-70 group-hover:opacity-100 transition-opacity">
                  Browse <ArrowRight class="w-3.5 h-3.5" />
                </div>
              )}
            </Wrapper>
          );
        })
      }
    </div>
  </section>
</Layout>
