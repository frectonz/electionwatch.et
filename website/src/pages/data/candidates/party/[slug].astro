---
import Layout from "@/layouts/Layout.astro";
import {
  candidateParties,
  loadAllCandidates,
  findConstituency,
  regionSlugByName,
  regionAggregation,
  peopleRings,
  educationChart,
  type Party,
  type Candidate,
} from "@/data/candidates";
import { fmt, pct, BALLOT_COLORS } from "@/lib/format";
import StatTiles from "@/components/StatTiles.astro";
import BallotBadge from "@/components/BallotBadge.astro";
import BallotLegend from "@/components/BallotLegend.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import PartyFootprintMap from "@/components/PartyFootprintMap.astro";
import { ArrowRight, MessageSquareQuote, MapPin } from "@lucide/astro";

type ContestedRow = {
  region: string;
  regionSlug: string;
  body: "hopr" | "rc";
  name: string;
  slug: string | null;
  candidates: number;
  pollingStations: number;
};

export function getStaticPaths() {
  const byParty = new Map<string, Candidate[]>();
  for (const c of loadAllCandidates()) {
    const list = byParty.get(c.party) ?? [];
    list.push(c);
    byParty.set(c.party, list);
  }

  return candidateParties.map((party) => {
    const candidates = byParty.get(party.name) ?? [];
    // Roll candidates up into the constituencies the party contests.
    const seats = new Map<string, ContestedRow>();
    for (const c of candidates) {
      const key = `${c.body}|${c.region}|${c.constituency}`;
      let row = seats.get(key);
      if (!row) {
        const con = findConstituency(c.body, c.region, c.constituency);
        row = {
          region: c.region,
          regionSlug: regionSlugByName.get(c.region) ?? "",
          body: c.body,
          name: c.constituency,
          slug: con?.slug ?? null,
          candidates: 0,
          pollingStations: con?.polling_stations ?? 0,
        };
        seats.set(key, row);
      }
      row.candidates++;
    }
    const contested = [...seats.values()].sort(
      (a, b) => a.region.localeCompare(b.region) || b.candidates - a.candidates,
    );
    return {
      params: { slug: party.slug },
      props: { party, candidates, contested },
    };
  });
}

const { party, candidates, contested } = Astro.props as {
  party: Party;
  candidates: Candidate[];
  contested: ContestedRow[];
};
const HOPR = BALLOT_COLORS.hopr;
const RC = BALLOT_COLORS.rc;

const female = candidates.filter((c) => c.gender === "Female").length;
const disabled = candidates.filter((c) => c.disability).length;
const totalStations = contested.reduce((a, r) => a + r.pollingStations, 0);

// Per-region totals.
const regionRows = regionAggregation(candidates);

const stats = [
  { label: "Candidates", value: party.candidates },
  { label: "HoPR", value: party.hopr },
  { label: "Regional Council", value: party.rc },
  { label: "Constituencies", value: contested.length },
];

// Group contested seats by region for the navigable list.
const byRegion = new Map<string, ContestedRow[]>();
for (const row of contested) {
  const list = byRegion.get(row.region) ?? [];
  list.push(row);
  byRegion.set(row.region, list);
}
const regionGroups = [...byRegion.entries()].sort((a, b) =>
  a[0].localeCompare(b[0]),
);

const regionChart = {
  names: regionRows.map((r) => r.name),
  hopr: regionRows.map((r) => r.hopr),
  rc: regionRows.map((r) => r.rc),
};
const genderChart = peopleRings(
  female,
  candidates.length - female,
  disabled,
  candidates.length,
);
// Education distribution, sorted by candidate count (desc).
const eduChart = educationChart(candidates);

// Footprint map: the candidate-constituency slugs this party contests, split by
// ballot. Constituencies with no polling-station match won't appear as dots.
const contestedHopr = contested
  .filter((r) => r.body === "hopr" && r.slug)
  .map((r) => r.slug as string);
const contestedRc = contested
  .filter((r) => r.body === "rc" && r.slug)
  .map((r) => r.slug as string);
const mappedSeats = contestedHopr.length + contestedRc.length;
---

<Layout
  title={`${party.name_en} candidates · electionwatch.et`}
  description={`Candidate breakdown for ${party.name_en} (${party.name}) in Ethiopia's 7th General Election, by region, ballot, and constituency.`}
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
    <Breadcrumbs
      items={[
        { label: "Data", href: "/data" },
        { label: "Candidates", href: "/data/candidates" },
        { label: party.name_en },
      ]}
    />
    <p class="text-ew-text-muted text-sm uppercase tracking-wider mb-1">
      Party
    </p>
    <h1 class="font-display text-4xl sm:text-5xl mb-1">{party.name_en}</h1>
    <p class="text-ew-text-muted">{party.name}</p>

    <StatTiles
      tiles={stats}
      class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6"
    />

    <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm">
      <span class="text-ew-text-dim">
        {fmt(female)} women ({pct(female, party.candidates)}%)
      </span>
      {
        totalStations > 0 && (
          <span class="text-ew-text-dim inline-flex items-center gap-1.5">
            <MapPin class="w-3.5 h-3.5 text-ew-text-muted" />
            {fmt(totalStations)} polling stations across its constituencies
          </span>
        )
      }
      {
        party.profile_slug && (
          <a
            href={`/parties/${party.profile_slug}`}
            class="inline-flex items-center gap-1.5 text-ew-shell hover:text-ew-gold font-medium"
          >
            <MessageSquareQuote class="w-4 h-4" />
            Read its positions from the debates
            <ArrowRight class="w-3.5 h-3.5" />
          </a>
        )
      }
    </div>
  </section>

  <!-- Region chart -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
      <h2 class="font-display text-2xl">Where they&rsquo;re standing</h2>
      <BallotLegend />
    </div>
    <div class="bg-ew-card border border-ew-card-border rounded-xl p-4">
      <div
        id="regionChart"
        data-chart={JSON.stringify(regionChart)}
        data-colors={JSON.stringify({ hopr: HOPR, rc: RC })}
        style={`height:${Math.max(200, regionRows.length * 32 + 24)}px`}
      >
      </div>
    </div>
  </section>

  <!-- Footprint map -->
  {
    mappedSeats > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        <h2 class="font-display text-2xl mb-1">On the map</h2>
        <p class="text-ew-text-dim text-sm mb-4 max-w-2xl">
          Every GPS-located polling station, coloured by whether {party.name_en}{" "}
          fields candidates in the constituency that votes there. Switch ballots
          to compare its HoPR and Regional Council footprint. Constituencies
          NEBE left without coordinates are not shown.
        </p>
        <PartyFootprintMap
          contestedHopr={contestedHopr}
          contestedRc={contestedRc}
          partyName={party.name_en}
        />
      </section>
    )
  }

  <!-- Demographics -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
    <div class="grid lg:grid-cols-5 gap-4">
      <div
        class="bg-ew-card border border-ew-card-border rounded-xl p-5 lg:col-span-2"
      >
        <h3 class="font-display text-lg mb-1">Gender &amp; disability</h3>
        <p class="text-xs text-ew-text-muted mb-1">
          Inner ring: gender. Outer ring: disability.
        </p>
        <div
          id="genderChart"
          data-chart={JSON.stringify(genderChart)}
          style="height:280px"
        >
        </div>
      </div>
      <div
        class="bg-ew-card border border-ew-card-border rounded-xl p-5 lg:col-span-3"
      >
        <h3 class="font-display text-lg mb-1">Education</h3>
        <div
          id="eduChart"
          data-chart={JSON.stringify(eduChart)}
          style="height:300px"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- Constituencies contested (navigable + filterable) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16" id="contested">
    <h2 class="font-display text-2xl mb-1">Constituencies contested</h2>
    <p class="text-ew-text-dim text-sm mb-4 max-w-2xl">
      Every seat {party.name_en} is fielding candidates for. Each links to its candidates
      and the polling stations that vote on them.
    </p>

    <div class="flex flex-wrap items-center gap-2 mb-4" id="ballotFilter">
      <span class="text-xs uppercase tracking-wider text-ew-text-muted mr-1"
        >Ballot</span
      >
      {
        [
          { k: "all", label: "All" },
          { k: "hopr", label: "HoPR" },
          { k: "rc", label: "Regional Council" },
        ].map((f, i) => (
          <button
            data-ballot={f.k}
            class:list={[
              "px-3 py-1.5 rounded-full text-sm border transition-colors",
              i === 0
                ? "bg-ew-shell text-white border-ew-shell"
                : "bg-ew-card text-ew-text-dim border-ew-card-border hover:border-ew-shell/40",
            ]}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <div class="space-y-6">
      {
        regionGroups.map(([region, rows]) => (
          <div
            class="region-group"
            data-region={region}
            data-hopr={rows.some((r) => r.body === "hopr") ? "1" : ""}
            data-rc={rows.some((r) => r.body === "rc") ? "1" : ""}
          >
            <div class="flex items-baseline justify-between gap-2 mb-2">
              <h3 class="font-display text-lg">{region}</h3>
              <a
                href={`/data/candidates/${rows[0].regionSlug}`}
                class="text-xs text-ew-shell hover:text-ew-gold"
              >
                Region overview &rsaquo;
              </a>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
              {rows.map((r) => {
                const Tag = r.slug ? "a" : "div";
                return (
                  <Tag
                    href={r.slug ? `/data/candidates/c/${r.slug}` : undefined}
                    class:list={[
                      "seat group bg-ew-card border border-ew-card-border rounded-lg px-4 py-3",
                      r.slug && "hover:border-ew-shell/40 transition-colors",
                    ]}
                    data-body={r.body}
                  >
                    <div class="flex items-center gap-2 mb-1">
                      <BallotBadge body={r.body} />
                      <span class="min-w-0 text-ew-text text-sm truncate group-hover:text-ew-shell transition-colors">
                        {r.name}
                      </span>
                    </div>
                    <div class="text-xs text-ew-text-muted">
                      {fmt(r.candidates)}{" "}
                      {r.candidates === 1 ? "candidate" : "candidates"}
                      {r.pollingStations > 0 &&
                        ` · ${fmt(r.pollingStations)} polling stations`}
                    </div>
                  </Tag>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <script>
    // Ballot filter for the contested-constituencies list.
    const filter = document.getElementById("ballotFilter");
    if (filter) {
      const buttons = [...filter.querySelectorAll<HTMLButtonElement>("button")];
      const apply = (mode: string) => {
        document.querySelectorAll<HTMLElement>(".seat").forEach((el) => {
          const show = mode === "all" || el.dataset.body === mode;
          el.style.display = show ? "" : "none";
        });
        document.querySelectorAll<HTMLElement>(".region-group").forEach((g) => {
          const has = mode === "all" || g.dataset[mode] === "1";
          g.style.display = has ? "" : "none";
        });
        buttons.forEach((b) => {
          const active = b.dataset.ballot === mode;
          b.classList.toggle("bg-ew-shell", active);
          b.classList.toggle("text-white", active);
          b.classList.toggle("border-ew-shell", active);
          b.classList.toggle("text-ew-text-dim", !active);
          b.classList.toggle("border-ew-card-border", !active);
        });
      };
      buttons.forEach((b) =>
        b.addEventListener("click", () => apply(b.dataset.ballot!)),
      );
    }
  </script>

  <script>
    import { initCandidateCharts } from "@/scripts/candidate-charts";
    initCandidateCharts();
  </script>
</Layout>
