---
import Layout from "@/layouts/Layout.astro";
import {
  allDebates,
  allParties,
  SOURCES,
  SOURCE_LABELS,
  formatDate,
  formatDuration,
  type Source,
} from "@/data";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { ArrowRight } from "@lucide/astro";

// Parties ranked by how many of the analysed debates they took part in.
const appearanceParties = allParties
  .filter((p) => p.debateCount > 0)
  .sort(
    (a, b) => b.debateCount - a.debateCount || a.name.localeCompare(b.name),
  );
const appearanceChart = {
  labels: appearanceParties.map((p) => p.name),
  counts: appearanceParties.map((p) => p.debateCount),
  slugs: appearanceParties.map((p) => p.slug),
  total: allDebates.length,
};
---

<Layout
  title="Debates · electionwatch.et"
  description="Debate broadcasts from Ethiopia's 7th General Election."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <Breadcrumbs
      items={[{ label: "Data", href: "/data" }, { label: "Debates" }]}
    />
    <h1 class="font-display text-4xl sm:text-5xl mb-4">
      {allDebates.length} debates
    </h1>
    <p class="text-ew-text-dim text-lg max-w-2xl">
      Every claim links to its YouTube timestamp.
    </p>
  </section>

  <!-- Parties by appearance -->
  {
    appearanceParties.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
        <h2 class="font-display text-2xl mb-1">Parties by appearance</h2>
        <p class="text-ew-text-dim text-sm mb-4 max-w-2xl">
          How many of the {allDebates.length} analysed debates each party took
          part in. Select a bar to open that party&rsquo;s profile.
        </p>
        <div class="bg-ew-card border border-ew-card-border rounded-xl p-4">
          <div
            id="appearanceChart"
            data-chart={JSON.stringify(appearanceChart)}
            style={`height:${Math.max(220, appearanceParties.length * 28 + 24)}px`}
          />
        </div>
      </section>
    )
  }

  {
    SOURCES.map((source: Source) => {
      const debates = allDebates.filter((d) => d.meta.source === source);
      if (debates.length === 0) return null;
      return (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
          <div class="flex items-end justify-between mb-4">
            <h2 class="font-display text-2xl">{SOURCE_LABELS[source]}</h2>
            <span class="text-sm text-ew-text-muted font-mono">
              {debates.length} {debates.length === 1 ? "debate" : "debates"}
            </span>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {debates.map((d) => (
              <a
                href={`/data/debates/${d.meta.video_id}`}
                class="group bg-ew-card border border-ew-card-border rounded-xl p-5 hover:border-ew-shell/40 hover:shadow-md transition-all"
              >
                <div class="flex items-center gap-2 text-[11px] uppercase tracking-wider text-ew-text-muted mb-3">
                  <span>{formatDate(d.meta.upload_date)}</span>
                  <span>&middot;</span>
                  <span class="font-mono">
                    {formatDuration(d.meta.duration_seconds)}
                  </span>
                  <span>&middot;</span>
                  <span class="font-mono">{d.analysis.questions.length} Q</span>
                </div>
                <h3 class="font-display text-xl mb-2 group-hover:text-ew-shell transition-colors leading-tight">
                  {d.analysis.title}
                </h3>
                <p class="text-ew-text-dim text-sm leading-snug line-clamp-2">
                  {d.analysis.overall_topic}
                </p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {d.meta.parties.slice(0, 4).map((p) => (
                    <span class="text-[11px] px-2 py-0.5 rounded-full border border-ew-card-border text-ew-text-dim">
                      {p.name}
                    </span>
                  ))}
                  {d.meta.parties.length > 4 && (
                    <span class="text-[11px] px-2 py-0.5 rounded-full text-ew-text-muted">
                      +{d.meta.parties.length - 4}
                    </span>
                  )}
                </div>
                <div class="mt-4 text-xs text-ew-shell inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  Read <ArrowRight class="w-3 h-3" />
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })
  }

  <script>
    // Horizontal bar of parties by debate appearances. Clicking a bar opens
    // the party's profile.
    import * as echarts from "echarts";
    import {
      grad,
      barShadow,
      offsetTooltip,
      narrowYLabels,
      tooltipBox,
      tipTitle,
      tipRow,
      MUTED,
      GRID,
      INK,
    } from "@/scripts/chart-style";

    const el = document.getElementById("appearanceChart");
    if (el) {
      const d = JSON.parse(el.dataset.chart!) as {
        labels: string[];
        counts: number[];
        slugs: string[];
        total: number;
      };
      const chart = echarts.init(el);
      chart.setOption({
        baseOption: {
          grid: { left: 4, right: 16, top: 4, bottom: 4, containLabel: true },
          tooltip: {
            ...tooltipBox,
            trigger: "axis",
            axisPointer: { type: "shadow" },
            confine: true,
            position: offsetTooltip,
            formatter: (
              p: { name: string; value: number; marker: string }[],
            ) => {
              const n = p[0].value;
              const share = Math.round((n / d.total) * 100);
              return (
                tipTitle(p[0].name) +
                tipRow(
                  "Debates",
                  `${n.toLocaleString()} of ${d.total.toLocaleString()}`,
                  p[0].marker,
                ) +
                tipRow("Share", `${share}%`)
              );
            },
          },
          xAxis: {
            type: "value",
            axisLabel: { show: false },
            axisLine: { show: false },
            splitLine: { lineStyle: { color: GRID } },
            minInterval: 1,
          },
          yAxis: {
            type: "category",
            inverse: true,
            data: d.labels,
            axisLabel: { color: MUTED, fontSize: 12 },
            axisTick: { show: false },
            axisLine: { show: false },
          },
          series: [
            {
              type: "bar",
              data: d.counts,
              cursor: "pointer",
              itemStyle: {
                color: grad(INK, "h"),
                borderRadius: [0, 4, 4, 0],
                ...barShadow,
              },
              barWidth: "62%",
            },
          ],
        },
        media: narrowYLabels,
      });

      chart.on("click", (params: { dataIndex: number }) => {
        const slug = d.slugs[params.dataIndex];
        if (slug) window.location.href = `/parties/${slug}`;
      });

      const ro = new ResizeObserver(() => chart.resize());
      ro.observe(el);
    }
  </script>
</Layout>
