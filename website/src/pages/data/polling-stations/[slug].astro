---
import Layout from "@/layouts/Layout.astro";
import PollingStationMap from "@/components/PollingStationMap.astro";
import {
  regions,
  hoprConstituencies,
  loadStations,
  type PollingStation,
} from "@/data/pollingStations";
import {
  candidateRegionBySlug,
  candidateConstituencyByStation,
} from "@/data/candidates";
import DataGrid, {
  type GridColumn,
  type GridRow,
} from "@/components/DataGrid.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { Users } from "@lucide/astro";
import { fmt, pct, GOLD, INK } from "@/lib/format";

export function getStaticPaths() {
  return regions.map((r) => ({
    params: { slug: r.slug },
    props: { region: r },
  }));
}

const { region } = Astro.props;

const stations: PollingStation[] = [
  ...loadStations(region.slug, "digital"),
  ...loadStations(region.slug, "manual"),
];

// Zones and woredas in this region by station count.
const zoneCount = new Map<string, number>();
const woredaSet = new Set<string>();
for (const s of stations) {
  zoneCount.set(s.zone, (zoneCount.get(s.zone) ?? 0) + 1);
  woredaSet.add(`${s.zone}/${s.woreda}`);
}
const zones = [...zoneCount.entries()].sort((a, b) => b[1] - a[1]);

const located = stations.filter((s) => s.coordinate_source === "nebe").length;

const constituencies = hoprConstituencies
  .filter((c) => c.region === region.name)
  .sort((a, b) => b.stations - a.stations);

// Zone + constituency tables.
const zoneColumns: GridColumn[] = [
  { label: "Zone", grow: 2 },
  { label: "Polling stations", numeric: true, grow: 0.8 },
];
const constituencyColumns: GridColumn[] = [
  { label: "Constituency", grow: 2 },
  { label: "Polling stations", numeric: true, grow: 0.8 },
];
const zoneRows: GridRow[] = zones.map(([zone, count]) => ({
  cells: [{ text: zone }, { text: count }],
}));
const constituencyRows: GridRow[] = constituencies.map((c) => {
  const cand = candidateConstituencyByStation("hopr", c.code);
  return {
    cells: [
      {
        text: c.name,
        sub: cand ? `#${c.code} · ${cand.candidates} candidates` : `#${c.code}`,
        href: cand ? `/data/candidates/c/${cand.slug}` : null,
      },
      { text: c.stations },
    ],
  };
});

const stats = [
  { label: "Polling stations", value: fmt(region.stations) },
  { label: "Zones", value: fmt(zones.length) },
  { label: "Woredas", value: fmt(woredaSet.size) },
  { label: "HoPR constituencies", value: fmt(constituencies.length) },
];

// Registration method, overall and per zone.
const hasBothMethods = region.digital > 0 && region.manual > 0;
const zoneReg = new Map<string, { online: number; inperson: number }>();
for (const s of stations) {
  const z = zoneReg.get(s.zone) ?? { online: 0, inperson: 0 };
  if (s.registration_type === "digital") z.online++;
  else z.inperson++;
  zoneReg.set(s.zone, z);
}
const zoneRegSorted = [...zoneReg.entries()].sort(
  (a, b) => b[1].online + b[1].inperson - (a[1].online + a[1].inperson),
);
const zoneChart = {
  names: zoneRegSorted.map(([z]) => z),
  online: zoneRegSorted.map(([, v]) => v.online),
  inperson: zoneRegSorted.map(([, v]) => v.inperson),
};
const zoneChartHeight = Math.min(
  1100,
  Math.max(220, zoneChart.names.length * 26 + 50),
);

// Constituency size stats within this region (constituencies sorted desc).
const cCounts = constituencies.map((c) => c.stations).sort((a, b) => a - b);
const cSum = cCounts.reduce((a, b) => a + b, 0);
const largestC = constituencies[0];
const smallestC = constituencies[constituencies.length - 1];
const conStats = [
  {
    label: "Average stations",
    value: cCounts.length ? Math.round(cSum / cCounts.length) : 0,
  },
  {
    label: "Median stations",
    value: cCounts.length ? cCounts[Math.floor(cCounts.length / 2)] : 0,
  },
  { label: "Smallest", value: smallestC?.stations ?? 0, sub: smallestC?.name },
  { label: "Largest", value: largestC?.stations ?? 0, sub: largestC?.name },
];
---

<Layout
  title={`${region.name} polling stations · electionwatch.et`}
  description={`Polling stations in ${region.name} for Ethiopia's 7th General Election.`}
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
    <Breadcrumbs
      items={[
        { label: "Data", href: "/data" },
        { label: "Polling Stations", href: "/data/polling-stations" },
        { label: region.name },
      ]}
    />
    <h1 class="font-display text-4xl sm:text-5xl mb-1">{region.name}</h1>
    <p class="text-ew-text-muted">{region.name_native}</p>
    {
      candidateRegionBySlug.has(region.slug) && (
        <a
          href={`/data/candidates/${region.slug}`}
          class="mt-3 inline-flex items-center gap-2 text-sm text-ew-shell hover:text-ew-gold"
        >
          <Users class="w-4 h-4" />
          {fmt(candidateRegionBySlug.get(region.slug)!.candidates)} candidates
          standing in {region.name} &rsaquo;
        </a>
      )
    }

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6">
      {
        stats.map((s) => (
          <div class="bg-ew-card border border-ew-card-border rounded-xl p-5">
            <dt class="text-ew-text-muted uppercase tracking-wider text-xs mb-1">
              {s.label}
            </dt>
            <dd class="font-display text-3xl tabular-nums">{s.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
    <p class="text-sm text-ew-text-muted mb-3">
      {
        located === 0
          ? "NEBE published no GPS coordinates for this region's stations."
          : `${fmt(located)} of ${fmt(region.stations)} stations (${pct(located, region.stations)}%) have GPS coordinates published by NEBE; the rest are not shown.`
      }
    </p>
    <PollingStationMap
      dataUrl={`/data/polling-stations-map/${region.slug}.json`}
      height="60vh"
      fitData
    />
  </section>

  <!-- Registration method -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
    <h2 class="font-display text-2xl mb-4">Registration method</h2>
    <div class="flex flex-wrap gap-3 mb-4">
      {
        region.digital > 0 && (
          <div class="flex items-baseline gap-2 bg-ew-card border border-ew-card-border rounded-xl px-4 py-3">
            <span
              class="w-3 h-3 rounded-full inline-block"
              style={`background:${GOLD}`}
            />
            <span class="font-display text-2xl tabular-nums">
              {fmt(region.digital)}
            </span>
            <span class="text-sm text-ew-text-muted">
              online · {pct(region.digital, region.stations)}%
            </span>
          </div>
        )
      }
      {
        region.manual > 0 && (
          <div class="flex items-baseline gap-2 bg-ew-card border border-ew-card-border rounded-xl px-4 py-3">
            <span
              class="w-3 h-3 rounded-full inline-block"
              style={`background:${INK}`}
            />
            <span class="font-display text-2xl tabular-nums">
              {fmt(region.manual)}
            </span>
            <span class="text-sm text-ew-text-muted">
              in-person · {pct(region.manual, region.stations)}%
            </span>
          </div>
        )
      }
    </div>
    {
      hasBothMethods && (
        <div class="bg-ew-card border border-ew-card-border rounded-xl p-4">
          <h3 class="text-sm text-ew-text-muted mb-2">By zone</h3>
          <div
            id="zoneChart"
            data-chart={JSON.stringify(zoneChart)}
            style={`height:${zoneChartHeight}px`}
          />
        </div>
      )
    }
  </section>

  <!-- Constituency sizes -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
    <h2 class="font-display text-2xl mb-4">Constituency sizes</h2>
    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {
        conStats.map((s) => (
          <div class="bg-ew-card border border-ew-card-border rounded-xl p-4">
            <dt class="text-ew-text-muted uppercase tracking-wider text-xs mb-1">
              {s.label}
            </dt>
            <dd class="font-display text-2xl tabular-nums">{fmt(s.value)}</dd>
            {s.sub && (
              <dd class="text-xs text-ew-text-muted mt-0.5 truncate">
                {s.sub}
              </dd>
            )}
          </div>
        ))
      }
    </dl>
  </section>

  <section
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 grid lg:grid-cols-2 gap-8 items-start"
  >
    <div>
      <h2 class="font-display text-2xl mb-4">Zones</h2>
      <DataGrid
        columns={zoneColumns}
        rows={zoneRows}
        defaultSort={1}
        defaultDir="desc"
        searchPlaceholder="Search zones"
        maxHeight="560px"
      />
    </div>

    <div>
      <h2 class="font-display text-2xl mb-4">
        Constituencies
        <span class="text-sm text-ew-text-muted font-mono font-normal">
          ({fmt(constituencies.length)})
        </span>
      </h2>
      <DataGrid
        columns={constituencyColumns}
        rows={constituencyRows}
        defaultSort={1}
        defaultDir="desc"
        searchPlaceholder="Search constituencies"
        maxHeight="560px"
      />
    </div>
  </section>

  <script>
    import * as echarts from "echarts";
    import {
      grad,
      barShadow,
      offsetTooltip,
      MONO,
      MUTED,
      GRID,
      INK,
    } from "@/scripts/chart-style";
    import { GOLD } from "@/lib/format";

    const axisLabel = { color: MUTED, fontFamily: MONO, fontSize: 11 };

    const el = document.getElementById("zoneChart");
    if (el) {
      const d = JSON.parse(el.dataset.chart!);
      const chart = echarts.init(el);
      chart.setOption({
        grid: { left: 8, right: 16, top: 30, bottom: 8, containLabel: true },
        legend: {
          data: ["Online", "In-person"],
          top: 0,
          textStyle: { color: MUTED },
        },
        tooltip: {
          trigger: "axis",
          axisPointer: { type: "shadow" },
          confine: true,
          enterable: false,
          transitionDuration: 0.2,
          position: offsetTooltip,
          formatter: (
            params: {
              name: string;
              seriesName: string;
              value: number;
              marker: string;
            }[],
          ) => {
            const total = params.reduce((a, p) => a + (p.value || 0), 0);
            const rows = params
              .map(
                (p) =>
                  `${p.marker} ${p.seriesName}: ${(p.value || 0).toLocaleString()}`,
              )
              .join("<br>");
            return `<strong>${params[0].name}</strong><br>${rows}<br>Total: ${total.toLocaleString()}`;
          },
        },
        xAxis: {
          type: "value",
          axisLabel: {
            ...axisLabel,
            formatter: (v: number) => v.toLocaleString(),
          },
          splitLine: { lineStyle: { color: GRID } },
        },
        yAxis: {
          type: "category",
          inverse: true,
          position: "right",
          data: d.names,
          axisLabel,
          axisTick: { show: false },
          axisLine: { lineStyle: { color: GRID } },
        },
        series: [
          {
            name: "Online",
            type: "bar",
            stack: "t",
            data: d.online,
            itemStyle: { color: grad(GOLD, "h"), ...barShadow },
          },
          {
            name: "In-person",
            type: "bar",
            stack: "t",
            data: d.inperson,
            itemStyle: { color: grad(INK, "h") },
          },
        ],
      });
      new ResizeObserver(() => chart.resize()).observe(el);
    }
  </script>
</Layout>
