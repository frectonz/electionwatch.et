---
import Layout from "@/layouts/Layout.astro";
import { allParties } from "@/data";
import { candidateParties } from "@/data/candidates";
import { fmt } from "@/lib/format";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { ArrowRight, Quote, MessagesSquare, Users } from "@lucide/astro";

// Parties with a debate-position profile.
const withPositions = allParties.filter((p) => p.positions.length > 0);
const positionSlugs = new Set(withPositions.map((p) => p.slug));

// The full ballot is every party fielding candidates, including the grouped
// "Independent" bucket (individual candidates rolled up into one entry). Those
// without a debate profile are listed below.
const ballotParties = candidateParties;
const withoutPositions = ballotParties
  .filter((p) => !(p.profile_slug && positionSlugs.has(p.profile_slug)))
  .sort((a, b) => b.candidates - a.candidates);
---

<Layout
  title="Parties · electionwatch.et"
  description="Parties on the ballot for Ethiopia's 7th General Election, with debate positions where available."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <Breadcrumbs items={[{ label: "Parties" }]} />
    <h1 class="font-display text-4xl sm:text-5xl mb-4">
      {fmt(ballotParties.length)} parties on the ballot
    </h1>
    <p class="text-ew-text-dim text-lg max-w-2xl">
      {withPositions.length} have position files compiled from their debate appearances.
      The rest field candidates but haven&rsquo;t appeared in an analysed debate,
      including the candidates running as independents, grouped here as one entry.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <h2
      class="font-display text-xl text-ew-text-muted uppercase tracking-wider mb-4"
    >
      With debate positions
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
      {
        withPositions.map((p) => (
          <a
            href={`/parties/${p.slug}`}
            class="group bg-ew-card border border-ew-card-border rounded-xl p-5 hover:border-ew-shell/40 hover:shadow-md transition-all flex flex-col"
          >
            <h3 class="font-display text-lg leading-tight group-hover:text-ew-shell transition-colors">
              {p.name}
            </h3>
            <div class="flex-1" />
            <div class="mt-4 flex items-center justify-between text-xs text-ew-text-muted">
              <span class="inline-flex items-center gap-1.5">
                <Quote class="w-3.5 h-3.5" />
                {p.positions.length} positions
              </span>
              <span class="inline-flex items-center gap-1.5">
                <MessagesSquare class="w-3.5 h-3.5" />
                {p.debateCount} debates
              </span>
              <ArrowRight class="w-4 h-4 text-ew-shell opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {
    withoutPositions.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <h2 class="font-display text-xl text-ew-text-muted uppercase tracking-wider mb-1">
          On the ballot, no debate appearance yet
        </h2>
        <p class="text-ew-text-dim text-sm mb-4 max-w-2xl">
          These parties are fielding candidates but haven&rsquo;t appeared in an
          analysed debate. Each links to its candidate breakdown.
        </p>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
          {withoutPositions.map((p) => (
            <a
              href={`/data/candidates/party/${p.slug}`}
              class="group bg-ew-card border border-ew-card-border rounded-lg px-4 py-3 hover:border-ew-shell/40 transition-colors"
            >
              <div class="text-sm text-ew-text group-hover:text-ew-shell transition-colors leading-tight">
                {p.name_en}
              </div>
              <div class="mt-1 text-xs text-ew-text-muted inline-flex items-center gap-1.5">
                <Users class="w-3 h-3" />
                {fmt(p.candidates)} candidates
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }
</Layout>
