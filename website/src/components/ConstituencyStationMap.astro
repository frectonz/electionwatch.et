---
// Map of the polling stations in a single candidate constituency. Points come
// from a per-constituency dataset (public/data/polling-stations-map/
// constituencies/{slug}.json) keyed by the candidate-side slug, built by
// scripts/build-ps-points.ts. Only stations NEBE published GPS coordinates for
// are shown; we never invent locations. Coloured by registration type — every
// dot here belongs to the same constituency, so there is nothing to toggle.
interface Props {
  /** Candidate constituency slug, used to fetch its station dataset. */
  slug: string;
  /** CSS height of the map. */
  height?: string;
}
const { slug, height = "60vh" } = Astro.props;

const id = "csmap-" + Math.random().toString(36).slice(2, 8);
// Point colour by registration type: online (digital) = gold, in-person
// (manual) = navy.
const COLORS = { online: "#c79a3a", inperson: "#1f2455" };
const config = {
  colors: COLORS,
  dataUrl: `/data/polling-stations-map/constituencies/${slug}.json`,
};
---

<style is:global>
  .ps-pop-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
  }
  .ps-pop-chip::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
  }
  .ps-pop-chip--online {
    color: #94701c;
    background: rgba(199, 154, 58, 0.18);
  }
  .ps-pop-chip--inperson {
    color: #1f2455;
    background: rgba(31, 36, 85, 0.1);
  }
</style>

<div>
  <div
    id={`${id}-legend`}
    class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ew-text-dim mb-3"
  >
    <span class="inline-flex items-center gap-2">
      <span
        class="w-3 h-3 rounded-full inline-block"
        style={`background:${COLORS.online}`}></span>
      Online registration
    </span>
    <span class="inline-flex items-center gap-2">
      <span
        class="w-3 h-3 rounded-full inline-block"
        style={`background:${COLORS.inperson}`}></span>
      In-person registration
    </span>
  </div>
  <div class="relative">
    <div
      id={id}
      class="cs-map-root w-full rounded-xl border border-ew-card-border overflow-hidden bg-ew-card"
      style={`height:${height};min-height:340px;`}
      data-config={JSON.stringify(config)}
    >
    </div>
    <div
      id={`${id}-empty`}
      class="hidden absolute inset-0 grid place-items-center pointer-events-none"
    >
      <p
        class="bg-ew-card/95 border border-ew-card-border rounded-lg px-4 py-3 text-sm text-ew-text-dim max-w-xs text-center"
      >
        NEBE did not publish GPS coordinates for this constituency&rsquo;s
        polling stations, so there is nothing to map.
      </p>
    </div>
    <div
      id={`${id}-hint`}
      class="absolute inset-0 grid place-items-center pointer-events-none transition-opacity duration-200"
    >
      <span
        class="bg-ew-text/70 text-white text-sm rounded-full px-4 py-2 backdrop-blur-sm"
      >
        Click the map to zoom
      </span>
    </div>
  </div>
</div>

<script>
  import { Popup, LngLatBounds } from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import {
    createMap,
    initScrollZoom,
    wireCursor,
    esc,
    CIRCLE_PAINT_BASE,
    type MapData,
  } from "@/lib/map";

  interface CsConfig {
    colors: { online: string; inperson: string };
    dataUrl: string;
  }
  interface CsProps {
    name: string;
    woreda: string;
    region: string;
    type: string;
  }

  document
    .querySelectorAll<HTMLElement>(".cs-map-root")
    .forEach((container) => {
      const id = container.id;
      const { colors, dataUrl }: CsConfig = JSON.parse(
        container.dataset.config!,
      );

      const map = createMap(id);
      const hint = initScrollZoom(map, container, id);

      async function load() {
        const data = (await fetch(dataUrl).then((r) => r.json())) as MapData;

        if (!data.points.length) {
          document.getElementById(id + "-empty")!.classList.remove("hidden");
          hint.style.display = "none";
          document.getElementById(id + "-legend")!.style.display = "none";
          return;
        }

        const bounds = new LngLatBounds();
        const fc: GeoJSON.FeatureCollection = {
          type: "FeatureCollection",
          features: data.points.map(
            ([lat, lon, regIdx, typeIdx, name, woreda]): GeoJSON.Feature => {
              bounds.extend([lon, lat]);
              const props: CsProps = {
                name,
                woreda: woreda ?? "",
                region: data.regions[regIdx],
                type: typeIdx === 0 ? "digital" : "manual",
              };
              return {
                type: "Feature",
                geometry: { type: "Point", coordinates: [lon, lat] },
                properties: props,
              };
            },
          ),
        };

        if (!bounds.isEmpty()) {
          map.fitBounds(bounds, { padding: 40, maxZoom: 13, duration: 0 });
        }

        map.addSource("stations", { type: "geojson", data: fc });
        map.addLayer({
          id: "station-point",
          type: "circle",
          source: "stations",
          paint: {
            "circle-color": [
              "match",
              ["get", "type"],
              "digital",
              colors.online,
              colors.inperson,
            ],
            ...CIRCLE_PAINT_BASE,
          },
        });

        map.on("click", "station-point", (e) => {
          const f = e.features![0];
          const p = f.properties as CsProps;
          const where = [p.woreda, p.region]
            .filter(Boolean)
            .map(esc)
            .join(" &middot; ");
          const online = p.type === "digital";
          const label = online
            ? "Online registration"
            : "In-person registration";
          new Popup({ offset: 12, maxWidth: "300px", closeButton: true })
            .setLngLat(
              (f.geometry as GeoJSON.Point).coordinates as [number, number],
            )
            .setHTML(
              `<div>
             <div class="ew-pop-head">
               <div class="ew-pop-title">${esc(p.name)}</div>
               ${where ? `<div class="ew-pop-sub">${where}</div>` : ""}
             </div>
             <div class="ew-pop-body">
               <span class="ps-pop-chip ps-pop-chip--${online ? "online" : "inperson"}">${label}</span>
             </div>
           </div>`,
            )
            .addTo(map);
        });
        wireCursor(map, "station-point");
      }

      if (map.loaded()) load();
      else map.on("load", load);
    });
</script>
