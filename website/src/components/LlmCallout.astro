---
// "Explore this with your favorite LLM" callout: one-click launchers that open
// the data prefilled in ChatGPT / Claude / Perplexity, plus a copy-prompt
// button for any other assistant. Used on the home page.
// Self-contained — the script enhances the instance on the page.
import { Sparkles, ArrowUpRight, Copy } from "@lucide/astro";
import { Icon } from "astro-icon/components";

const SITE = "https://electionwatch.et";
const LLMS_URL = `${SITE}/llms.txt`;

// The ready-made prompt we copy / prefill. It points the model at llms.txt,
// which maps every dataset and links the raw JSON.
const AGENT_PROMPT = `Read ${LLMS_URL} — it's the entry point for electionwatch.et, an open-data project on Ethiopia's 7th General Election. It maps every dataset (candidates, polling stations, debate analyses, party positions, and ballot symbols) and links to the raw JSON, with the full file list at ${SITE}/data/manifest.json. Refer to it and look up the data directly from the site as you help me explore and analyze it.`;

// All three accept the prompt straight from the URL (?q=), so the chat opens
// prefilled and ready to send. For any other assistant, the Copy prompt button
// is the fallback. Logos come from the Simple Icons set via astro-icon.
const assistants = [
  {
    name: "ChatGPT",
    href: `https://chatgpt.com/?q=${encodeURIComponent(AGENT_PROMPT)}`,
    icon: "simple-icons:openai",
  },
  {
    name: "Claude",
    href: `https://claude.ai/new?q=${encodeURIComponent(AGENT_PROMPT)}`,
    icon: "simple-icons:claude",
  },
  {
    name: "Perplexity",
    href: `https://www.perplexity.ai/search/new?q=${encodeURIComponent(AGENT_PROMPT)}`,
    icon: "simple-icons:perplexity",
  },
];
---

<div
  data-llm-cta
  data-prompt={AGENT_PROMPT}
  class="bg-ew-gold-soft border border-ew-gold/20 rounded-xl p-6 sm:p-8 flex flex-col gap-4"
>
  <div class="flex items-start gap-3">
    <div
      class="w-10 h-10 rounded-lg bg-ew-shell/10 grid place-items-center shrink-0"
    >
      <Sparkles class="w-5 h-5 text-ew-shell" />
    </div>
    <div class="min-w-0">
      <h2 class="font-display text-2xl text-ew-text leading-tight">
        Explore this with your favorite LLM
      </h2>
      <p
        class="text-ew-text-dim text-sm sm:text-base leading-relaxed mt-2 max-w-2xl"
      >
        Every dataset here is machine-readable. Open it in your assistant and
        ask your own questions of the data.
      </p>
    </div>
  </div>

  <!-- One-click launchers -->
  <div class="flex flex-wrap gap-2">
    {
      assistants.map((a) => (
        <a
          href={a.href}
          target="_blank"
          rel="noopener noreferrer"
          data-open
          class="inline-flex items-center gap-2 bg-ew-card border border-ew-card-border rounded-lg px-4 py-2 text-sm font-medium text-ew-text hover:border-ew-shell/40 transition-colors"
        >
          <Icon name={a.icon} class="w-4 h-4 text-ew-text" />
          Open in {a.name}
          <ArrowUpRight class="w-3.5 h-3.5 text-ew-text-muted" />
        </a>
      ))
    }
    <button
      type="button"
      data-copy
      class="inline-flex items-center gap-2 bg-ew-shell text-white rounded-lg px-4 py-2 text-sm font-medium hover:opacity-90 transition-opacity"
    >
      <Copy class="w-4 h-4" /> Copy AI prompt
    </button>
  </div>

  <details class="text-xs text-ew-text-muted">
    <summary class="cursor-pointer hover:text-ew-shell select-none">
      Preview the prompt
    </summary>
    <p
      class="mt-2 bg-ew-card border border-ew-card-border rounded-lg p-3 text-ew-text-dim leading-relaxed font-mono"
    >
      {AGENT_PROMPT}
    </p>
  </details>
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-llm-cta]");
  if (root) {
    const prompt = root.dataset.prompt ?? "";
    const copyPrompt = async (): Promise<boolean> => {
      try {
        await navigator.clipboard.writeText(prompt);
        return true;
      } catch {
        return false;
      }
    };
    // Copy the prompt on every launch too, so it's on the clipboard as a backup.
    root
      .querySelectorAll<HTMLAnchorElement>("[data-open]")
      .forEach((el) => el.addEventListener("click", () => void copyPrompt()));

    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy]");
    if (copyBtn) {
      const original = copyBtn.innerHTML;
      const copied =
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M20 6 9 17l-5-5"/></svg> Copied!';
      let timer = 0;
      copyBtn.addEventListener("click", () => {
        void copyPrompt().then((ok) => {
          copyBtn.innerHTML = ok ? copied : original;
          clearTimeout(timer);
          timer = window.setTimeout(() => {
            copyBtn.innerHTML = original;
          }, 2000);
        });
      });
    }
  }
</script>
