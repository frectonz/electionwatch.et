---
// Map of one party's footprint: every GPS-located polling station, coloured by
// whether this party fields candidates in the constituency voted on there.
// "Running here" dots take the ballot colour; the rest fade to faint grey, so a
// single glance shows where the party stands and where it leaves a gap. A ballot
// toggle switches between the HoPR and Regional Council races, whose coverage
// differs. Reuses the global map JSON built by build-ps-points.ts.
import { BALLOT_COLORS } from "@/lib/format";

interface Props {
  /** Candidate-constituency slugs the party contests on the HoPR ballot. */
  contestedHopr: string[];
  /** Candidate-constituency slugs the party contests on the RC ballot. */
  contestedRc: string[];
  partyName: string;
  height?: string;
}
const { contestedHopr, contestedRc, partyName, height = "68vh" } = Astro.props;

const id = "pfmap-" + Math.random().toString(36).slice(2, 8);
const GREY = "#d4d7e1"; // faint "not running" dots
// One fixed colour means "running here" in either ballot; the toggle alone says
// which race you're looking at, so the colour shouldn't shift with it.
const COLORS = { run: BALLOT_COLORS.hopr, grey: GREY };
// Which ballot to show first: prefer whichever the party actually contests.
const startMode = contestedHopr.length >= contestedRc.length ? "hopr" : "rc";
const config = {
  colors: COLORS,
  sets: { hopr: contestedHopr, rc: contestedRc },
  startMode,
  partyName,
};
---

<style is:global>
  .pf-pop-status {
    font-size: 13px;
    color: var(--color-ew-text);
    line-height: 1.35;
  }
  .pf-pop-status strong {
    color: var(--color-ew-shell);
  }
  .pf-pop-link {
    display: inline-block;
    margin-top: 7px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-ew-shell);
    text-decoration: none;
  }
  .pf-pop-link:hover {
    color: var(--color-ew-gold);
  }
</style>

<div>
  <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2 mb-3">
    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ew-text-dim">
      <span class="inline-flex items-center gap-2">
        <span
          class="w-3 h-3 rounded-full inline-block"
          style={`background:${COLORS.run}`}></span>
        Running here
      </span>
      <span class="inline-flex items-center gap-2">
        <span
          class="w-3 h-3 rounded-full inline-block"
          style={`background:${GREY}`}></span>
        Not running
      </span>
    </div>
    <div
      id={`${id}-mode`}
      class="inline-flex rounded-lg border border-ew-card-border overflow-hidden text-xs"
    >
      <button
        data-mode="hopr"
        class:list={[
          "px-3 py-1.5 font-medium",
          startMode === "hopr"
            ? "bg-ew-shell text-white"
            : "bg-ew-card text-ew-text-dim hover:text-ew-shell",
        ]}
      >
        HoPR
      </button>
      <button
        data-mode="rc"
        class:list={[
          "px-3 py-1.5 font-medium",
          startMode === "rc"
            ? "bg-ew-shell text-white"
            : "bg-ew-card text-ew-text-dim hover:text-ew-shell",
        ]}
      >
        Regional Council
      </button>
    </div>
  </div>
  <div class="relative">
    <div
      id={id}
      class="pf-map-root w-full rounded-xl border border-ew-card-border overflow-hidden bg-ew-card"
      style={`height:${height};min-height:360px;`}
      data-config={JSON.stringify(config)}
    >
    </div>
    <div
      id={`${id}-hint`}
      class="absolute inset-0 grid place-items-center pointer-events-none transition-opacity duration-200"
    >
      <span
        class="bg-ew-text/70 text-white text-sm rounded-full px-4 py-2 backdrop-blur-sm"
      >
        Click the map to zoom
      </span>
    </div>
  </div>
</div>

<script>
  import { Popup, type ExpressionSpecification } from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import {
    createMap,
    initScrollZoom,
    wireModeToggle,
    wireCursor,
    esc,
    matchColor,
    CIRCLE_PAINT_BASE,
    type MapData,
  } from "@/lib/map";

  interface PfConfig {
    colors: { run: string; grey: string };
    sets: { hopr: string[]; rc: string[] };
    startMode: "hopr" | "rc";
    partyName: string;
  }
  interface PfProps {
    name: string;
    woreda: string;
    region: string;
    chopr: string;
    crc: string;
    hslug: string;
    hname: string;
    rslug: string;
    rname: string;
  }

  document
    .querySelectorAll<HTMLElement>(".pf-map-root")
    .forEach((container) => {
      const id = container.id;
      const { colors, sets, startMode, partyName }: PfConfig = JSON.parse(
        container.dataset.config!,
      );
      // Contested constituency slugs become Sets for O(1) membership tests.
      const setOf = { hopr: new Set(sets.hopr), rc: new Set(sets.rc) };
      const prop = (mode: string) => (mode === "hopr" ? "chopr" : "crc");

      const map = createMap(id);
      initScrollZoom(map, container, id);

      async function load() {
        const data = (await fetch("/data/polling-stations-map.json").then((r) =>
          r.json(),
        )) as MapData;
        const { hoprC, rcC } = data;

        const fc: GeoJSON.FeatureCollection = {
          type: "FeatureCollection",
          features: data.points.map(
            ([
              lat,
              lon,
              regIdx,
              ,
              name,
              woreda,
              hIdx,
              rIdx,
            ]): GeoJSON.Feature => {
              const h = hIdx >= 0 ? hoprC[hIdx] : null;
              const r = rIdx >= 0 ? rcC[rIdx] : null;
              const props: PfProps = {
                name,
                woreda: woreda ?? "",
                region: data.regions[regIdx],
                chopr: h && setOf.hopr.has(h.slug) ? "1" : "",
                crc: r && setOf.rc.has(r.slug) ? "1" : "",
                hslug: h ? h.slug : "",
                hname: h ? h.name : "",
                rslug: r ? r.slug : "",
                rname: r ? r.name : "",
              };
              return {
                type: "Feature",
                geometry: { type: "Point", coordinates: [lon, lat] },
                properties: props,
              };
            },
          ),
        };

        const colorFor = (mode: string) =>
          matchColor(prop(mode), "1", colors.run, colors.grey);
        // Draw the contested (coloured) dots on top of the grey ones.
        const sortFor = (mode: string): ExpressionSpecification => [
          "case",
          ["==", ["get", prop(mode)], "1"],
          1,
          0,
        ];

        map.addSource("stations", { type: "geojson", data: fc });
        map.addLayer({
          id: "station-point",
          type: "circle",
          source: "stations",
          // circle-sort-key is a layout property: contested dots (1) draw above
          // the grey (0) ones so a small footprint never gets buried.
          layout: { "circle-sort-key": sortFor(startMode) },
          paint: { "circle-color": colorFor(startMode), ...CIRCLE_PAINT_BASE },
        });

        let mode = startMode;
        wireModeToggle(id, (m) => {
          mode = m as "hopr" | "rc";
          map.setPaintProperty("station-point", "circle-color", colorFor(m));
          map.setLayoutProperty("station-point", "circle-sort-key", sortFor(m));
        });

        map.on("click", "station-point", (e) => {
          const f = e.features![0];
          const p = f.properties as PfProps;
          const where = [p.woreda, p.region]
            .filter(Boolean)
            .map(esc)
            .join(" &middot; ");
          const running = (mode === "hopr" ? p.chopr : p.crc) === "1";
          const conName = mode === "hopr" ? p.hname : p.rname;
          const conSlug = mode === "hopr" ? p.hslug : p.rslug;
          const bodyLabel = mode === "hopr" ? "HoPR" : "Regional Council";
          let status;
          if (!conName) {
            status = `No ${bodyLabel} constituency is linked to this station.`;
          } else if (running) {
            status =
              `<strong>${esc(partyName)}</strong> is running here for ` +
              `${bodyLabel} in ${esc(conName)}.`;
          } else {
            status =
              `${esc(partyName)} is <strong>not</strong> running here for ` +
              `${bodyLabel} (${esc(conName)}).`;
          }
          const link =
            conSlug && conName
              ? `<a class="pf-pop-link" href="/data/candidates/c/${conSlug}">See this constituency &rsaquo;</a>`
              : "";
          new Popup({ offset: 12, maxWidth: "300px", closeButton: true })
            .setLngLat(
              (f.geometry as GeoJSON.Point).coordinates as [number, number],
            )
            .setHTML(
              `<div>
             <div class="ew-pop-head">
               <div class="ew-pop-title">${esc(p.name)}</div>
               ${where ? `<div class="ew-pop-sub">${where}</div>` : ""}
             </div>
             <div class="ew-pop-body">
               <p class="pf-pop-status">${status}</p>
               ${link}
             </div>
           </div>`,
            )
            .addTo(map);
        });
        wireCursor(map, "station-point");
      }

      if (map.loaded()) load();
      else map.on("load", load);
    });
</script>
