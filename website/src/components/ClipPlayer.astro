---
import { Play } from "@lucide/astro";
import { Icon } from "astro-icon/components";

interface Props {
  defaultVideoId?: string;
  defaultLabel?: string;
  placeholder?: string;
}
const {
  defaultVideoId = "",
  defaultLabel = "Full debate",
  placeholder = "Click any clip to start playing",
} = Astro.props;

const initialSrc = defaultVideoId
  ? `https://www.youtube.com/embed/${defaultVideoId}?rel=0&enablejsapi=1`
  : "";

// Buttons that appear below the timeline; toggled by display in the script.
const btnBase =
  "justify-center items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium transition-colors";
const btnPrimary = `${btnBase} bg-ew-shell text-white hover:opacity-90`;
const btnGhost = `${btnBase} bg-ew-surface border border-ew-card-border text-ew-text hover:border-ew-shell/40`;
---

<section
  id="player-bar"
  class="sticky top-16 z-30 bg-ew-bg border-y border-ew-card-border"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="grid lg:grid-cols-[420px_1fr] gap-4">
      <div
        id="player-container"
        class="aspect-video bg-ew-surface border border-ew-card-border rounded-lg overflow-hidden shrink-0 max-w-full"
      >
        {
          defaultVideoId ? (
            <iframe
              id="clip-player"
              src={initialSrc}
              class="w-full h-full border-0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          ) : (
            <div
              id="player-placeholder"
              class="w-full h-full flex flex-col items-center justify-center text-center text-ew-text-muted px-4"
            >
              <Play class="w-8 h-8 mb-2 opacity-50" />
              <p class="text-sm">{placeholder}</p>
            </div>
          )
        }
      </div>

      <div class="min-w-0 flex flex-col gap-2">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p
              class="text-[10px] uppercase tracking-wider text-ew-text-muted mb-0.5"
            >
              Now playing
            </p>
            <p
              id="now-playing-label"
              class="font-display text-base sm:text-lg text-ew-text leading-tight truncate"
            >
              {defaultVideoId ? defaultLabel : "Nothing yet"}
            </p>
          </div>
          <button
            type="button"
            data-reset-player
            class={`text-xs text-ew-text-muted hover:text-ew-shell shrink-0 ${defaultVideoId ? "" : "hidden"}`}
          >
            {defaultVideoId ? "Reset" : "Clear"}
          </button>
        </div>

        <div id="clip-progress" class="hidden">
          <div class="relative h-1.5 bg-ew-surface rounded overflow-hidden">
            <div
              id="clip-progress-fill"
              class="absolute inset-y-0 left-0 bg-ew-gold"
              style="width:0%"
            >
            </div>
          </div>
          <div
            class="flex justify-between items-center text-[10px] font-mono text-ew-text-muted mt-1 gap-2"
          >
            <span id="clip-progress-time">0:00 / 0:00</span>
            <a
              id="clip-open-youtube"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="uppercase tracking-wider inline-flex items-center gap-1 hover:text-ew-shell shrink-0"
            >
              <Icon name="simple-icons:youtube" class="w-3 h-3" />
              Continue on YouTube
            </a>
          </div>

          <!-- Shown for a cued clip (e.g. opened from a ?clip= link). -->
          <button
            type="button"
            id="clip-play"
            style="display:none"
            class={`mt-2 w-full ${btnPrimary}`}
          >
            <Play class="w-3.5 h-3.5" />
            Play clip
          </button>

          <!-- Shown when a clip reaches its end. -->
          <div
            id="clip-ended-actions"
            style="display:none"
            class="mt-2 flex gap-2"
          >
            <button
              type="button"
              id="clip-replay"
              class={`flex-1 inline-flex ${btnGhost}`}
            >
              <Play class="w-3.5 h-3.5" />
              Play again
            </button>
            <a
              id="clip-continue"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class={`flex-1 inline-flex ${btnPrimary}`}
            >
              <Icon name="simple-icons:youtube" class="w-3.5 h-3.5" />
              Continue on YouTube
            </a>
          </div>
        </div>

        <slot />
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ defaultVideoId, defaultLabel }}>
  (function () {
    const el = {
      container: document.getElementById("player-container"),
      label: document.getElementById("now-playing-label"),
      bar: document.getElementById("player-bar"),
      progress: document.getElementById("clip-progress"),
      fill: document.getElementById("clip-progress-fill"),
      time: document.getElementById("clip-progress-time"),
      openYT: document.getElementById("clip-open-youtube"),
      endedActions: document.getElementById("clip-ended-actions"),
      continueYT: document.getElementById("clip-continue"),
      replay: document.getElementById("clip-replay"),
      play: document.getElementById("clip-play"),
      reset: document.querySelector("[data-reset-player]"),
    };
    if (!el.container || !el.label || !el.progress || !el.fill || !el.time) {
      return;
    }

    const EMBED_ALLOW =
      "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
    const hasDefault = !!defaultVideoId;

    let player = null;
    let playerReady = false;
    let iframeCreated = hasDefault;
    let onReady = null; // a single action to run once the player is ready
    let active = null; // { videoId, start, end, label } of the current clip
    let rafId = null;
    let lastSec = -1;

    // --- formatting -----------------------------------------------------------
    const pad = (n) => String(n).padStart(2, "0");
    function clock(s) {
      if (!Number.isFinite(s)) return "0:00";
      s = Math.max(0, Math.floor(s));
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      return h > 0 ? h + ":" + pad(m) + ":" + pad(sec) : m + ":" + pad(sec);
    }
    const clamp = (sec) => Math.max(0, Math.floor(sec));
    // The full video at a given second, so "continue" resumes where you are.
    const watchUrl = (id, sec) =>
      "https://www.youtube.com/watch?v=" + id + "&t=" + clamp(sec) + "s";
    const embedUrl = (id, start, end, autoplay) =>
      "https://www.youtube.com/embed/" +
      id +
      "?start=" +
      Math.floor(start) +
      "&end=" +
      Math.ceil(end) +
      "&autoplay=" +
      (autoplay ? "1" : "0") +
      "&rel=0&enablejsapi=1";

    // --- show/hide the toggled controls --------------------------------------
    const toggle = (node, on) => {
      if (node) node.style.display = on ? "flex" : "none";
    };
    const showPlay = (on) => toggle(el.play, on);
    const hideEnded = () => toggle(el.endedActions, false);
    function showEnded(sec) {
      if (!active || !el.endedActions) return;
      if (el.continueYT) el.continueYT.href = watchUrl(active.videoId, sec);
      toggle(el.endedActions, true);
    }

    // --- progress bar (driven by requestAnimationFrame for smoothness) --------
    function renderProgress() {
      if (!active || !player || !player.getCurrentTime) return;
      const t = player.getCurrentTime();
      const dur = active.end - active.start;
      // getCurrentTime() can return NaN for a tick right after a load.
      if (!Number.isFinite(t) || dur <= 0) return;
      const elapsed = Math.max(0, Math.min(dur, t - active.start));
      el.fill.style.width = (elapsed / dur) * 100 + "%";
      // Text + link only change once a second — no need to touch them per frame.
      const sec = Math.floor(elapsed);
      if (sec !== lastSec) {
        lastSec = sec;
        el.time.textContent = clock(elapsed) + " / " + clock(dur);
        if (el.openYT) el.openYT.href = watchUrl(active.videoId, t);
      }
      if (t >= active.end - 0.4) showEnded(t);
    }
    function startTracking() {
      stopTracking();
      lastSec = -1;
      const tick = () => {
        renderProgress();
        rafId = requestAnimationFrame(tick);
      };
      rafId = requestAnimationFrame(tick);
    }
    function stopTracking() {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
    }

    // --- YouTube iframe + player ----------------------------------------------
    function ensurePlayer() {
      if (window.YT && window.YT.Player) {
        createPlayer();
        return;
      }
      window.onYouTubeIframeAPIReady = createPlayer;
      const tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      tag.async = true;
      document.head.appendChild(tag);
    }
    function createPlayer() {
      try {
        player = new YT.Player("clip-player", {
          events: {
            onReady: () => {
              playerReady = true;
              const action = onReady;
              onReady = null;
              if (action) action();
              else if (active) startTracking();
            },
            onStateChange: (e) => {
              if (!active) return;
              const S = YT.PlayerState;
              if (e.data === S.PLAYING) {
                startTracking();
                hideEnded();
                showPlay(false);
              } else if (e.data === S.ENDED) {
                stopTracking();
                showEnded(active.end);
              } else if (e.data === S.PAUSED) {
                stopTracking();
                renderProgress();
              }
            },
          },
        });
      } catch {
        /* iframe API failed to load */
      }
    }
    function mountIframe(videoId, start, end, autoplay) {
      const placeholder = document.getElementById("player-placeholder");
      if (placeholder) placeholder.remove();
      const iframe = document.createElement("iframe");
      iframe.id = "clip-player";
      iframe.src = embedUrl(videoId, start, end, autoplay);
      iframe.className = "w-full h-full";
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute("allow", EMBED_ALLOW);
      iframe.setAttribute("allowfullscreen", "true");
      el.container.appendChild(iframe);
      iframeCreated = true;
      ensurePlayer();
    }

    // --- loading / controlling clips ------------------------------------------
    function syncUrl(clip) {
      const url = new URL(window.location.href);
      if (clip) {
        url.searchParams.set(
          "clip",
          clip.videoId +
            ":" +
            Math.floor(clip.start) +
            "-" +
            Math.ceil(clip.end),
        );
      } else {
        url.searchParams.delete("clip");
      }
      window.history.replaceState({}, "", url);
    }

    function scrollIntoView(node) {
      if (node) node.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    function revealPlayerBar() {
      const rect = el.bar.getBoundingClientRect();
      if (rect.top < 0 || rect.bottom > window.innerHeight) {
        window.scrollTo({
          top: window.scrollY + rect.top - 64,
          behavior: "smooth",
        });
      }
    }

    // mode: "play" autoplays; "cue" loads paused and shows the Play button.
    function loadClip(videoId, start, end, name, youtubeUrl, mode) {
      const cue = mode === "cue";
      active = { videoId: videoId, start: start, end: end, label: name };
      syncUrl(active);

      el.label.textContent = name;
      el.progress.classList.remove("hidden");
      if (el.reset) el.reset.classList.remove("hidden");
      // Initial target = clip start; renderProgress() then tracks the live time.
      if (el.openYT && youtubeUrl) el.openYT.href = youtubeUrl;
      el.fill.style.width = "0%";
      el.time.textContent = "0:00 / " + clock(end - start);
      hideEnded();
      showPlay(cue);

      const opts = { videoId: videoId, startSeconds: start, endSeconds: end };
      if (!iframeCreated) {
        mountIframe(videoId, start, end, !cue);
      } else if (playerReady && player) {
        if (cue && player.cueVideoById) {
          player.cueVideoById(opts);
          stopTracking();
        } else {
          player.loadVideoById(opts);
          startTracking();
        }
      } else {
        const iframe = document.getElementById("clip-player");
        if (iframe) iframe.src = embedUrl(videoId, start, end, !cue);
        onReady = cue ? null : startTracking;
      }

      if (!cue) revealPlayerBar();
    }

    function playActive() {
      showPlay(false);
      if (!active) return;
      if (playerReady && player && player.playVideo) {
        if (player.seekTo) player.seekTo(active.start, true);
        player.playVideo();
        startTracking();
      } else {
        replayActive();
      }
    }
    function replayActive() {
      if (!active) return;
      loadClip(
        active.videoId,
        active.start,
        active.end,
        active.label,
        watchUrl(active.videoId, active.start),
        "play",
      );
    }
    function resetPlayer() {
      active = null;
      syncUrl(null);
      stopTracking();
      hideEnded();
      showPlay(false);
      el.progress.classList.add("hidden");
      if (hasDefault) {
        el.label.textContent = defaultLabel;
        if (playerReady && player && player.cueVideoById) {
          player.cueVideoById(defaultVideoId);
        }
      } else {
        el.label.textContent = "Nothing yet";
        if (el.reset) el.reset.classList.add("hidden");
        if (playerReady && player && player.stopVideo) player.stopVideo();
      }
    }

    // Restore a clip shared via ?clip=videoId:start-end. The param holds rounded
    // seconds, but the clip triggers carry exact times — so match on floor/ceil
    // and reuse the trigger's precise time, label and YouTube link.
    function applyClipFromUrl() {
      const param = new URLSearchParams(window.location.search).get("clip");
      const m =
        param && param.match(/^([^:]+):(\d+(?:\.\d+)?)-(\d+(?:\.\d+)?)$/);
      if (!m) return;
      const videoId = m[1];
      const startParam = Math.floor(parseFloat(m[2]));
      const endParam = Math.ceil(parseFloat(m[3]));

      let match = null;
      const triggers = document.querySelectorAll(
        '[data-clip-video-id="' + videoId + '"]',
      );
      for (let i = 0; i < triggers.length; i++) {
        const s = parseFloat(triggers[i].dataset.clipStart);
        const e = parseFloat(triggers[i].dataset.clipEnd);
        if (Math.floor(s) === startParam && Math.ceil(e) === endParam) {
          match = triggers[i].dataset;
          break;
        }
      }
      loadClip(
        videoId,
        match ? parseFloat(match.clipStart) : startParam,
        match ? parseFloat(match.clipEnd) : endParam,
        (match && match.clipLabel) || "Clip",
        (match && match.clipYoutube) || "",
        "cue",
      );
    }

    // --- wiring ---------------------------------------------------------------
    if (el.replay) el.replay.addEventListener("click", replayActive);
    if (el.play) el.play.addEventListener("click", playActive);

    document.addEventListener("click", (e) => {
      const target = e.target instanceof Element ? e.target : null;
      if (!target) return;

      const trigger = target.closest("[data-clip-video-id]");
      if (trigger instanceof HTMLElement) {
        e.preventDefault();
        const jump = trigger.dataset.jump;
        loadClip(
          trigger.dataset.clipVideoId,
          parseFloat(trigger.dataset.clipStart || "0"),
          parseFloat(trigger.dataset.clipEnd || "0"),
          trigger.dataset.clipLabel || "Clip",
          trigger.dataset.clipYoutube || "",
          jump ? "cue" : "play",
        );
        if (jump) scrollIntoView(document.getElementById(jump));
        return;
      }

      if (target.closest("[data-reset-player]")) resetPlayer();
    });

    if (hasDefault) ensurePlayer();

    // Defer until the clip triggers lower in the page are parsed (this inline
    // script runs before them), so we can resolve the clip's real title.
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", applyClipFromUrl);
    } else {
      applyClipFromUrl();
    }
  })();
</script>
