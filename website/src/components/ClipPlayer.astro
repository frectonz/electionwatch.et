---
import { Play } from "@lucide/astro";
import { Icon } from "astro-icon/components";

interface Props {
  defaultVideoId?: string;
  defaultLabel?: string;
  placeholder?: string;
}
const {
  defaultVideoId = "",
  defaultLabel = "Full debate",
  placeholder = "Click any clip to start playing",
} = Astro.props;

const initialSrc = defaultVideoId
  ? `https://www.youtube.com/embed/${defaultVideoId}?rel=0&enablejsapi=1`
  : "";
---

<section
  id="player-bar"
  class="sticky top-16 z-30 bg-ew-bg border-y border-ew-card-border"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="grid lg:grid-cols-[420px_1fr] gap-4">
      <div
        id="player-container"
        class="aspect-video bg-ew-surface border border-ew-card-border rounded-lg overflow-hidden shrink-0 max-w-full"
      >
        {
          defaultVideoId ? (
            <iframe
              id="clip-player"
              src={initialSrc}
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          ) : (
            <div
              id="player-placeholder"
              class="w-full h-full flex flex-col items-center justify-center text-center text-ew-text-muted px-4"
            >
              <Play class="w-8 h-8 mb-2 opacity-50" />
              <p class="text-sm">{placeholder}</p>
            </div>
          )
        }
      </div>

      <div class="min-w-0 flex flex-col gap-2">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p
              class="text-[10px] uppercase tracking-wider text-ew-text-muted mb-0.5"
            >
              Now playing
            </p>
            <p
              id="now-playing-label"
              class="font-display text-base sm:text-lg text-ew-text leading-tight truncate"
            >
              {defaultVideoId ? defaultLabel : "Nothing yet"}
            </p>
          </div>
          <button
            type="button"
            data-reset-player
            class={`text-xs text-ew-text-muted hover:text-ew-shell shrink-0 ${defaultVideoId ? "" : "hidden"}`}
          >
            {defaultVideoId ? "Reset" : "Clear"}
          </button>
        </div>

        <div id="clip-progress" class="hidden">
          <div class="relative h-1.5 bg-ew-surface rounded overflow-hidden">
            <div
              id="clip-progress-fill"
              class="absolute inset-y-0 left-0 bg-ew-gold transition-[width] duration-150 ease-linear"
              style="width:0%"
            >
            </div>
          </div>
          <div
            class="flex justify-between text-[10px] font-mono text-ew-text-muted mt-1"
          >
            <span id="clip-progress-time">0:00 / 0:00</span>
            <a
              id="clip-open-youtube"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="uppercase tracking-wider inline-flex items-center gap-1 hover:text-ew-shell"
            >
              <Icon name="simple-icons:youtube" class="w-3 h-3" />
              Open
            </a>
          </div>
        </div>

        <slot />
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ defaultVideoId, defaultLabel }}>
  (function () {
    const playerContainer = document.getElementById("player-container");
    const label = document.getElementById("now-playing-label");
    const playerBar = document.getElementById("player-bar");
    const progressBox = document.getElementById("clip-progress");
    const progressFill = document.getElementById("clip-progress-fill");
    const progressTime = document.getElementById("clip-progress-time");
    const openYT = document.getElementById("clip-open-youtube");
    const resetBtn = document.querySelector("[data-reset-player]");
    if (
      !playerContainer ||
      !label ||
      !progressBox ||
      !progressFill ||
      !progressTime
    )
      return;

    const hasDefault = !!defaultVideoId;

    let player = null;
    let playerReady = false;
    let iframeCreated = hasDefault;
    let pendingAfterReady = null;
    let activeClip = null;
    let pollTimer = null;

    function fmt(s) {
      s = Math.max(0, Math.floor(s));
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      const pad = (n) => String(n).padStart(2, "0");
      return h > 0 ? h + ":" + pad(m) + ":" + pad(sec) : m + ":" + pad(sec);
    }

    function clipUrl(videoId, start, end, mode) {
      const autoplay = mode === "cue" ? "0" : "1";
      return (
        "https://www.youtube.com/embed/" +
        videoId +
        "?start=" +
        Math.floor(start) +
        "&end=" +
        Math.ceil(end) +
        "&autoplay=" +
        autoplay +
        "&rel=0&enablejsapi=1"
      );
    }

    function scrollToSection(targetId) {
      const section = document.getElementById(targetId);
      if (!section) return;
      section.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function updateProgress() {
      if (!activeClip || !player || !player.getCurrentTime) return;
      const t = player.getCurrentTime();
      const clipDur = activeClip.end - activeClip.start;
      if (clipDur <= 0) return;
      const elapsed = Math.max(0, Math.min(clipDur, t - activeClip.start));
      progressFill.style.width = (elapsed / clipDur) * 100 + "%";
      progressTime.textContent = fmt(elapsed) + " / " + fmt(clipDur);
    }
    function startPolling() {
      stopPolling();
      pollTimer = window.setInterval(updateProgress, 250);
      updateProgress();
    }
    function stopPolling() {
      if (pollTimer) {
        window.clearInterval(pollTimer);
        pollTimer = null;
      }
    }

    function createIframe(videoId, start, end, mode) {
      const placeholder = document.getElementById("player-placeholder");
      if (placeholder && placeholder.parentNode === playerContainer) {
        playerContainer.removeChild(placeholder);
      }
      const iframe = document.createElement("iframe");
      iframe.id = "clip-player";
      iframe.src = clipUrl(videoId, start, end, mode);
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute(
        "allow",
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture",
      );
      iframe.setAttribute("allowfullscreen", "true");
      iframe.className = "w-full h-full";
      playerContainer.appendChild(iframe);
      iframeCreated = true;
      loadYouTubeApi();
    }

    function loadYouTubeApi() {
      if (window.YT && window.YT.Player) {
        initPlayer();
        return;
      }
      window.onYouTubeIframeAPIReady = initPlayer;
      const tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      tag.async = true;
      document.head.appendChild(tag);
    }

    function initPlayer() {
      try {
        player = new YT.Player("clip-player", {
          events: {
            onReady: function () {
              playerReady = true;
              if (pendingAfterReady) {
                const p = pendingAfterReady;
                pendingAfterReady = null;
                p();
              } else if (activeClip) {
                startPolling();
              }
            },
            onStateChange: function (e) {
              if (e.data === 1 && activeClip) startPolling();
            },
          },
        });
      } catch {
        return;
      }
    }

    function setClipParam(clip) {
      const url = new URL(window.location.href);
      if (clip) {
        url.searchParams.set(
          "clip",
          clip.videoId +
            ":" +
            Math.floor(clip.start) +
            "-" +
            Math.ceil(clip.end),
        );
      } else {
        url.searchParams.delete("clip");
      }
      window.history.replaceState({}, "", url);
    }

    function loadClip(videoId, start, end, name, youtubeUrl, mode) {
      activeClip = { videoId: videoId, start: start, end: end, label: name };
      setClipParam(activeClip);
      label.textContent = name;
      progressBox.classList.remove("hidden");
      if (resetBtn) resetBtn.classList.remove("hidden");
      if (openYT && youtubeUrl) openYT.setAttribute("href", youtubeUrl);
      progressFill.style.width = "0%";
      progressTime.textContent = "0:00 / " + fmt(end - start);

      const isCue = mode === "cue";

      if (!iframeCreated) {
        createIframe(videoId, start, end, mode);
      } else if (playerReady && player) {
        if (isCue && player.cueVideoById) {
          player.cueVideoById({
            videoId: videoId,
            startSeconds: start,
            endSeconds: end,
          });
          stopPolling();
        } else if (player.loadVideoById) {
          player.loadVideoById({
            videoId: videoId,
            startSeconds: start,
            endSeconds: end,
          });
          startPolling();
        }
      } else {
        const iframe = document.getElementById("clip-player");
        if (iframe) iframe.src = clipUrl(videoId, start, end, mode);
        pendingAfterReady = isCue
          ? null
          : function () {
              startPolling();
            };
      }

      if (!isCue) {
        const rect = playerBar.getBoundingClientRect();
        if (rect.top < 0 || rect.bottom > window.innerHeight) {
          window.scrollTo({
            top: window.scrollY + rect.top - 64,
            behavior: "smooth",
          });
        }
      }
    }

    function resetPlayer() {
      activeClip = null;
      setClipParam(null);
      stopPolling();
      progressBox.classList.add("hidden");
      if (hasDefault) {
        label.textContent = defaultLabel;
        if (playerReady && player && player.cueVideoById) {
          player.cueVideoById(defaultVideoId);
        }
      } else {
        label.textContent = "Nothing yet";
        if (resetBtn) resetBtn.classList.add("hidden");
        if (playerReady && player && player.stopVideo) {
          player.stopVideo();
        }
      }
    }

    if (hasDefault) loadYouTubeApi();

    (function applyClipFromUrl() {
      const param = new URLSearchParams(window.location.search).get("clip");
      if (!param) return;
      const m = param.match(/^([^:]+):(\d+(?:\.\d+)?)-(\d+(?:\.\d+)?)$/);
      if (!m) return;
      const vid = m[1];
      const start = parseFloat(m[2]);
      const end = parseFloat(m[3]);
      const btn = document.querySelector(
        '[data-clip-video-id="' +
          vid +
          '"][data-clip-start="' +
          m[2] +
          '"][data-clip-end="' +
          m[3] +
          '"]',
      );
      const lbl = (btn && btn.dataset && btn.dataset.clipLabel) || "Clip";
      const yt = (btn && btn.dataset && btn.dataset.clipYoutube) || "";
      loadClip(vid, start, end, lbl, yt, "cue");
    })();

    document.addEventListener("click", function (e) {
      const target = e.target instanceof Element ? e.target : null;
      if (!target) return;

      const playBtn = target.closest("[data-clip-video-id]");
      if (playBtn instanceof HTMLElement) {
        e.preventDefault();
        const jumpTarget = playBtn.dataset.jump;
        const mode = jumpTarget ? "cue" : "play";
        loadClip(
          playBtn.dataset.clipVideoId,
          parseFloat(playBtn.dataset.clipStart || "0"),
          parseFloat(playBtn.dataset.clipEnd || "0"),
          playBtn.dataset.clipLabel || "Clip",
          playBtn.dataset.clipYoutube || "",
          mode,
        );
        if (jumpTarget) scrollToSection(jumpTarget);
        return;
      }

      const reset = target.closest("[data-reset-player]");
      if (reset) resetPlayer();
    });
  })();
</script>
