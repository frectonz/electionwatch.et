---
// Reusable MapLibre map of polling stations with NEBE-published GPS coordinates.
// Rendered as individual GPU circle dots (fast at scale). Stations NEBE left
// without coordinates are not shown; we do not invent locations.
interface Props {
  /** Map data URL (global by default; pass a per-region file for region pages). */
  dataUrl?: string;
  /** CSS height of the map. */
  height?: string;
  /** Fit the view to the data bounds instead of the default Ethiopia view. */
  fitData?: boolean;
}
const {
  dataUrl = "/data/polling-stations-map.json",
  height = "72vh",
  fitData = false,
} = Astro.props;

const id = "psmap-" + Math.random().toString(36).slice(2, 8);
// Point colour by registration type: online (digital) = gold, in-person
// (manual) = navy.
const COLORS = { online: "#c79a3a", inperson: "#1f2455" };
const config = { colors: COLORS, dataUrl, fitData };
---

<style is:global>
  .ps-pop-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
  }
  .ps-pop-chip::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
  }
  .ps-pop-chip--online {
    color: #94701c;
    background: rgba(199, 154, 58, 0.18);
  }
  .ps-pop-chip--inperson {
    color: #1f2455;
    background: rgba(31, 36, 85, 0.1);
  }
  .ps-pop-ballots {
    margin-top: 11px;
    padding-top: 10px;
    border-top: 1px solid var(--color-ew-card-border);
  }
  .ps-pop-ballots-head {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ew-text-muted);
    margin-bottom: 6px;
  }
  .ps-pop-ballot {
    display: block;
    text-decoration: none;
    padding: 6px 8px;
    border-radius: 8px;
    border: 1px solid var(--color-ew-card-border);
    margin-top: 6px;
    transition: background 0.12s;
  }
  .ps-pop-ballot:hover {
    background: rgba(31, 36, 85, 0.05);
  }
  .ps-pop-ballot-body {
    display: inline-block;
    font-size: 9.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ew-shell);
  }
  .ps-pop-ballot-name {
    display: block;
    font-size: 13px;
    color: var(--color-ew-text);
    line-height: 1.25;
    margin: 1px 0;
  }
  .ps-pop-ballot-count {
    display: block;
    font-size: 11px;
    color: var(--color-ew-text-muted);
  }
</style>

<div>
  <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2 mb-3">
    <div
      id={`${id}-legend`}
      class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-ew-text-dim"
    >
      <span class="inline-flex items-center gap-2">
        <span
          class="w-3 h-3 rounded-full inline-block"
          style={`background:${COLORS.online}`}></span>
        Online registration
      </span>
      <span class="inline-flex items-center gap-2">
        <span
          class="w-3 h-3 rounded-full inline-block"
          style={`background:${COLORS.inperson}`}></span>
        In-person registration
      </span>
      <span
        id={`${id}-legend-con`}
        class="inline-flex items-center gap-2 text-ew-text-muted"
        style="display:none"
      >
        Each colour is a different HoPR constituency
      </span>
    </div>
    <div
      id={`${id}-mode`}
      class="inline-flex rounded-lg border border-ew-card-border overflow-hidden text-xs"
    >
      <button
        data-mode="con"
        class="px-3 py-1.5 font-medium bg-ew-shell text-white"
      >
        Constituency
      </button>
      <button
        data-mode="reg"
        class="px-3 py-1.5 font-medium bg-ew-card text-ew-text-dim hover:text-ew-shell"
      >
        Registration
      </button>
    </div>
  </div>
  <div class="relative">
    <div
      id={id}
      class="ps-map-root w-full rounded-xl border border-ew-card-border overflow-hidden bg-ew-card"
      style={`height:${height};min-height:360px;`}
      data-config={JSON.stringify(config)}
    >
    </div>
    <div
      id={`${id}-empty`}
      class="hidden absolute inset-0 grid place-items-center pointer-events-none"
    >
      <p
        class="bg-ew-card/95 border border-ew-card-border rounded-lg px-4 py-3 text-sm text-ew-text-dim max-w-xs text-center"
      >
        NEBE did not publish GPS coordinates for these polling stations, so
        there is nothing to map.
      </p>
    </div>
    <div
      id={`${id}-hint`}
      class="absolute inset-0 grid place-items-center pointer-events-none transition-opacity duration-200"
    >
      <span
        class="bg-ew-text/70 text-white text-sm rounded-full px-4 py-2 backdrop-blur-sm"
      >
        Click the map to zoom
      </span>
    </div>
  </div>
</div>

<script>
  import {
    Popup,
    LngLatBounds,
    type ExpressionSpecification,
  } from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import {
    createMap,
    initScrollZoom,
    wireModeToggle,
    wireCursor,
    esc,
    CIRCLE_PAINT_BASE,
    type MapData,
    type ConstituencyRef,
  } from "@/lib/map";

  interface PsConfig {
    colors: { online: string; inperson: string };
    dataUrl: string;
    fitData: boolean;
  }
  interface PsProps {
    name: string;
    woreda: string;
    region: string;
    type: string;
    hopr: string;
    rc: string;
    ccolor: string;
  }

  // Categorical palette for "colour by constituency" mode (cycled by index).
  const PALETTE = [
    "#b91c1c",
    "#4338ca",
    "#1f2455",
    "#b45309",
    "#7c3aed",
    "#0369a1",
    "#be123c",
    "#15803d",
    "#a16207",
    "#9333ea",
    "#0891b2",
    "#c2410c",
    "#4d7c0f",
    "#db2777",
    "#1d4ed8",
    "#65a30d",
    "#9f1239",
    "#047857",
  ];
  const NO_CONSTITUENCY = "#c2c6d2";

  document
    .querySelectorAll<HTMLElement>(".ps-map-root")
    .forEach((container) => {
      const id = container.id;
      const { colors, dataUrl, fitData }: PsConfig = JSON.parse(
        container.dataset.config!,
      );

      const map = createMap(id);
      const hint = initScrollZoom(map, container, id);

      async function load() {
        const data = (await fetch(dataUrl).then((r) => r.json())) as MapData;

        if (!data.points.length) {
          document.getElementById(id + "-empty")!.classList.remove("hidden");
          hint.style.display = "none";
          document.getElementById(id + "-legend")!.style.display = "none";
          document.getElementById(id + "-mode")!.style.display = "none";
          return;
        }

        const { hoprC, rcC } = data;
        const bounds = new LngLatBounds();
        const fc: GeoJSON.FeatureCollection = {
          type: "FeatureCollection",
          features: data.points.map(
            ([
              lat,
              lon,
              regIdx,
              typeIdx,
              name,
              woreda,
              hIdx,
              rIdx,
            ]): GeoJSON.Feature => {
              bounds.extend([lon, lat]);
              const props: PsProps = {
                name,
                woreda: woreda ?? "",
                region: data.regions[regIdx],
                type: typeIdx === 0 ? "digital" : "manual",
                hopr: hIdx >= 0 ? JSON.stringify(hoprC[hIdx]) : "",
                rc: rIdx >= 0 ? JSON.stringify(rcC[rIdx]) : "",
                ccolor:
                  hIdx >= 0 ? PALETTE[hIdx % PALETTE.length] : NO_CONSTITUENCY,
              };
              return {
                type: "Feature",
                geometry: { type: "Point", coordinates: [lon, lat] },
                properties: props,
              };
            },
          ),
        };

        if (fitData && !bounds.isEmpty()) {
          map.fitBounds(bounds, { padding: 40, maxZoom: 11, duration: 0 });
        }

        // digital = online, manual = in-person
        const REG_COLOR: ExpressionSpecification = [
          "match",
          ["get", "type"],
          "digital",
          colors.online,
          colors.inperson,
        ];
        const CON_COLOR: ExpressionSpecification = ["get", "ccolor"];

        map.addSource("stations", { type: "geojson", data: fc });
        map.addLayer({
          id: "station-point",
          type: "circle",
          source: "stations",
          paint: { "circle-color": CON_COLOR, ...CIRCLE_PAINT_BASE },
        });

        // Colour-by toggle: registration type vs HoPR constituency.
        const legend = document.getElementById(id + "-legend")!;
        const regSpans = [
          ...legend.querySelectorAll<HTMLElement>(":scope > span"),
        ].filter((s) => s.id !== id + "-legend-con");
        const conNote = document.getElementById(id + "-legend-con")!;
        const setMode = wireModeToggle(id, (mode) => {
          const con = mode === "con";
          map.setPaintProperty(
            "station-point",
            "circle-color",
            con ? CON_COLOR : REG_COLOR,
          );
          regSpans.forEach((s) => (s.style.display = con ? "none" : ""));
          conNote.style.display = con ? "" : "none";
        });
        setMode("con"); // constituency colouring is the default view

        map.on("click", "station-point", (e) => {
          const f = e.features![0];
          const p = f.properties as PsProps;
          const where = [p.woreda, p.region]
            .filter(Boolean)
            .map(esc)
            .join(" &middot; ");
          const online = p.type === "digital";
          const label = online
            ? "Online registration"
            : "In-person registration";
          const ballotRow = (raw: string, body: string) => {
            if (!raw) return "";
            const c = JSON.parse(raw) as ConstituencyRef;
            return `<a class="ps-pop-ballot" href="/data/candidates/c/${c.slug}">
            <span class="ps-pop-ballot-body">${body}</span>
            <span class="ps-pop-ballot-name">${esc(c.name)}</span>
            <span class="ps-pop-ballot-count">${c.candidates.toLocaleString()} candidates &rsaquo;</span>
          </a>`;
          };
          const ballots =
            ballotRow(p.hopr, "HoPR") + ballotRow(p.rc, "Regional Council");
          new Popup({ offset: 12, maxWidth: "320px", closeButton: true })
            .setLngLat(
              (f.geometry as GeoJSON.Point).coordinates as [number, number],
            )
            .setHTML(
              `<div>
             <div class="ew-pop-head">
               <div class="ew-pop-title">${esc(p.name)}</div>
               ${where ? `<div class="ew-pop-sub">${where}</div>` : ""}
             </div>
             <div class="ew-pop-body">
               <span class="ps-pop-chip ps-pop-chip--${online ? "online" : "inperson"}">${label}</span>
               ${ballots ? `<div class="ps-pop-ballots"><div class="ps-pop-ballots-head">On the ballot here</div>${ballots}</div>` : ""}
             </div>
           </div>`,
            )
            .addTo(map);
        });
        wireCursor(map, "station-point");
      }

      if (map.loaded()) load();
      else map.on("load", load);
    });
</script>
