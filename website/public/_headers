# Service worker must never be HTTP-cached — otherwise a broken /sw.js
# can stay pinned at the CDN edge for hours and brick repeat visitors.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/site.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json

# Agent entry point + open data: allow any tool (including browser-based LLM
# agents) to fetch these cross-origin.
/llms.txt
  Access-Control-Allow-Origin: *
  Content-Type: text/markdown; charset=utf-8

/data/*
  Access-Control-Allow-Origin: *

# Debate transcripts are Markdown — serve them as readable text, not a download.
/data/debates/*.md
  Content-Type: text/markdown; charset=utf-8
